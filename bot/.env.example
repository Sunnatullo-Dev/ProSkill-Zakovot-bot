# Zakovat Telegram bot sozlamalari.
# Bu faylni nusxalab `.env` deb nomlang va qiymatlarni to'ldiring.

# @BotFather dan olingan bot tokeni
TELEGRAM_BOT_TOKEN=

# Admin Telegram ID (kelajakda admin funksiyalari uchun)
ADMIN_ID=

# Mini App joylashtirilgan HTTPS manzili (deploydan keyin)
MINI_APP_URL=
