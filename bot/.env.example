# Zakovat Telegram bot sozlamalari.
# Bu faylni nusxalab `.env` deb nomlang va qiymatlarni to'ldiring.

# @BotFather dan olingan bot tokeni
TELEGRAM_BOT_TOKEN=

# Admin Telegram ID (kelajakda admin funksiyalari uchun)
ADMIN_ID=

# Mini App joylashtirilgan HTTPS manzili (deploydan keyin)
MINI_APP_URL=

# Backend URL (Render yoki lokal)
BACKEND_URL=

# Backend admin API uchun ALOHIDA kalit — Telegram bot tokeni EMAS.
# Backend env'idagi BOT_INTERNAL_API_KEY bilan AYNAN BIR XIL bo'lishi shart.
# Yaratish:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
BOT_INTERNAL_API_KEY=
