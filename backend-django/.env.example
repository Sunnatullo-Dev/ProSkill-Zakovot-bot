# Zakovat Django backend environment variables.
# Yangi loyihada bu faylni .env ga ko'chiring va o'zingiznikiga to'ldiring.

# Django asoslari
DJANGO_SECRET_KEY=
DJANGO_DEBUG=false
# Production'da aniq domain yozish shart (vergul bilan). Misol:
# DJANGO_ALLOWED_HOSTS=api.example.com,example.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# development | production. Production'da bo'lsa: guest fallback yo'q, CORS qattiq,
# kerakli env'lar majburiy.
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
PORT=3000

# Telegram bot tokeni — Telegram WebApp initData ni tekshirish uchun.
# @BotFather'dan oling.
TELEGRAM_BOT_TOKEN=

# Supabase service-role kalit — RLS ni chetlab o'tib hamma jadvalga yozish/o'qish.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Google Gemini API.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Admin Telegram ID lar — vergul bilan ajratiladi. Misol: 7566796449,1234567890
ADMIN_TELEGRAM_IDS=

# Telegram bot xabaridagi tugma uchun (HTTPS bo'lishi shart). Ixtiyoriy.
MINI_APP_URL=
