# Zakovat Django backend environment variables.
# Eski Node backend .env bilan bir xil — qiymatlarni ko'chiring.

DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
PORT=3001

# Production rejimi: faqat shu manzildan kelgan so'rovlarni qabul qiladi.
# Development rejimi: hamma manzil ruxsat etiladi.
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Telegram bot tokeni — Telegram WebApp initData ni tekshirish uchun.
TELEGRAM_BOT_TOKEN=

# Supabase service-role kalit — RLS ni chetlab o'tib hamma jadvalga yozish/o'qish.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Google Gemini API.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Admin Telegram ID lar — vergul bilan ajratiladi (masalan: 0,7566796449).
ADMIN_TELEGRAM_IDS=0
